# Backend local environment example
# Copy this file to backend/.env and fill in your test credentials.

TABLE_NAME=shopreturngifts
S3_BUCKET=shopreturngifts-assets
COGNITO_USER_POOL_ID=us-east-1_xxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_PROFILE=shopreturngifts-dev
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Use your Stripe Dashboard test keys (never commit real secrets)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STATEMENT_DESCRIPTOR_SUFFIX=SHOPRETURNGIFTS
STRIPE_IDEMPOTENCY_KEY_PREFIX=shopreturngifts
